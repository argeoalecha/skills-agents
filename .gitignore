# Track only skills/ — everything else is personal config, ephemeral, or
# potentially confidential (agents/ intentionally excluded since 2026-07-03 —
# stays local-only, was scrubbed from GitHub history)

# Ignore everything by default
*

# Re-include tracked directories
!.gitignore
!skills/
!skills/**

# Local-only exceptions inside skills/ (must come after the re-include)
skills/SESSION_CHECKPOINT.md
skills/.vscode/
.DS_Store
