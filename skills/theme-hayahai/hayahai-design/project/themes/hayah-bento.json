{
  "name": "Hayah Bento",
  "id": "hayah-bento",
  "version": "2.0",
  "description": "Modern bento grid aesthetic inspired by the best AI and tech landing pages of 2025. Asymmetric grid cards, gradient surfaces, glassmorphism on dark teal panels, and aqua green as a starring accent. Built for AI products, developer tools, and SaaS platforms that need to feel alive and cutting-edge.",
  "mood": "Innovative, dynamic, technical, premium",
  "inspiration": "Anthropic.com, Cursor, Perplexity, Luma — tech-forward bento grid landing pages",
  "colors": {
    "brand": {
      "primary": "#25A497",
      "primaryLight": "#A1E4DB",
      "primaryDark": "#1E6E66",
      "accent": "#ff6b47",
      "accentLight": "#ff8f73",
      "anchor": "#0a3d3a",
      "anchorDark": "#0F3836"
    },
    "gradient": {
      "tealRadial": "radial-gradient(ellipse at top left, #25A497 0%, #0a3d3a 70%)",
      "tealLinear": "linear-gradient(135deg, #1E6E66 0%, #0a3d3a 100%)",
      "aquaMint": "linear-gradient(135deg, #25A497 0%, #A1E4DB 100%)",
      "coralWarm": "linear-gradient(135deg, #ff8f73 0%, #ff6b47 100%)",
      "darkTeal": "linear-gradient(180deg, #1a4d47 0%, #0F3836 100%)",
      "mesh": "radial-gradient(at 0% 0%, rgba(37,164,151,0.3) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(255,107,71,0.15) 0px, transparent 50%)"
    },
    "interactive": {
      "link": "#25A497",
      "linkHover": "#ff6b47",
      "focus": "#25A497",
      "secondary": "#1E6E66",
      "muted": "#7a9b96"
    },
    "surface": {
      "page": "#faf7f5",
      "pageDark": "#0F3836",
      "card": "#ffffff",
      "cardTeal": "#e8f4f1",
      "cardDark": "#1C5753",
      "glass": "rgba(255, 255, 255, 0.7)",
      "glassDark": "rgba(28, 87, 83, 0.5)"
    },
    "text": {
      "primary": "#0a3d3a",
      "secondary": "#1C5753",
      "muted": "#7a9b96",
      "onDark": "#faf7f5",
      "onTeal": "#faf7f5",
      "onAccent": "#ffffff",
      "aqua": "#25A497"
    },
    "border": {
      "default": "rgba(161, 228, 219, 0.4)",
      "strong": "#A1E4DB",
      "dark": "rgba(161, 228, 219, 0.15)",
      "card": "rgba(10, 61, 58, 0.08)"
    }
  },
  "typography": {
    "fonts": {
      "display": "Space Grotesk",
      "heading": "Space Grotesk",
      "body": "Inter",
      "mono": "JetBrains Mono"
    },
    "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap",
    "notes": "Space Grotesk has a technical-yet-approachable character with distinctive letterforms, perfect for AI/tech products. Pairs naturally with Inter's neutral clarity.",
    "scale": {
      "hero": { "size": "80px", "lineHeight": "1.0", "weight": 700, "letterSpacing": "-0.04em", "font": "Space Grotesk" },
      "display": { "size": "60px", "lineHeight": "1.05", "weight": 700, "letterSpacing": "-0.03em", "font": "Space Grotesk" },
      "h1": { "size": "44px", "lineHeight": "1.15", "weight": 700, "letterSpacing": "-0.025em", "font": "Space Grotesk" },
      "h2": { "size": "32px", "lineHeight": "1.25", "weight": 600, "letterSpacing": "-0.02em", "font": "Space Grotesk" },
      "h3": { "size": "22px", "lineHeight": "1.35", "weight": 600, "letterSpacing": "-0.015em", "font": "Space Grotesk" },
      "h4": { "size": "17px", "lineHeight": "1.45", "weight": 600, "font": "Space Grotesk" },
      "bodyLg": { "size": "18px", "lineHeight": "1.7", "weight": 400, "font": "Inter" },
      "body": { "size": "16px", "lineHeight": "1.7", "weight": 400, "font": "Inter" },
      "bodySm": { "size": "14px", "lineHeight": "1.6", "weight": 400, "font": "Inter" },
      "caption": { "size": "12px", "lineHeight": "1.5", "weight": 500, "letterSpacing": "0.01em", "font": "Inter" },
      "label": { "size": "11px", "lineHeight": "1.4", "weight": 600, "letterSpacing": "0.08em", "font": "Space Grotesk", "textTransform": "uppercase" },
      "metric": { "size": "48px", "lineHeight": "1.0", "weight": 700, "letterSpacing": "-0.03em", "font": "Space Grotesk" },
      "code": { "size": "13px", "lineHeight": "1.5", "weight": 400, "font": "JetBrains Mono" }
    }
  },
  "components": {
    "button": {
      "primary": {
        "bg": "#25A497", "text": "#ffffff", "hover": "#1E6E66",
        "padding": "14px 28px", "borderRadius": "12px",
        "font": "Space Grotesk", "fontSize": "15px", "fontWeight": 600,
        "letterSpacing": "-0.01em",
        "boxShadow": "0 4px 16px rgba(37, 164, 151, 0.35)"
      },
      "primaryDark": {
        "bg": "#ff6b47", "text": "#ffffff", "hover": "#e55a38",
        "padding": "14px 28px", "borderRadius": "12px",
        "font": "Space Grotesk", "fontSize": "15px", "fontWeight": 600,
        "boxShadow": "0 4px 16px rgba(255, 107, 71, 0.35)"
      },
      "secondary": {
        "bg": "rgba(37, 164, 151, 0.1)", "text": "#0a3d3a",
        "border": "1px solid rgba(37, 164, 151, 0.4)",
        "hover": "rgba(37, 164, 151, 0.2)",
        "padding": "14px 28px", "borderRadius": "12px",
        "font": "Space Grotesk", "fontSize": "15px", "fontWeight": 500
      }
    },
    "bentoGrid": {
      "gap": "16px",
      "cards": {
        "hero-large": {
          "gridArea": "spans 2 cols, 2 rows",
          "bg": "linear-gradient(135deg, #1E6E66 0%, #0a3d3a 100%)",
          "text": "#faf7f5",
          "borderRadius": "24px", "padding": "48px",
          "minHeight": "360px"
        },
        "feature": {
          "gridArea": "1 col, 1 row",
          "bg": "#ffffff",
          "border": "1px solid rgba(161, 228, 219, 0.4)",
          "borderRadius": "20px", "padding": "28px",
          "boxShadow": "0 2px 16px rgba(10, 61, 58, 0.06)"
        },
        "metric": {
          "gridArea": "1 col, 1 row",
          "bg": "#e8f4f1",
          "borderRadius": "20px", "padding": "28px",
          "accentBar": "3px solid #25A497"
        },
        "highlight": {
          "gridArea": "1 col, 1 row",
          "bg": "#ff6b47", "text": "#ffffff",
          "borderRadius": "20px", "padding": "28px"
        },
        "glass": {
          "gridArea": "2 cols, 1 row",
          "bg": "rgba(255, 255, 255, 0.7)",
          "backdropFilter": "blur(16px)",
          "border": "1px solid rgba(161, 228, 219, 0.5)",
          "borderRadius": "20px", "padding": "32px"
        }
      }
    },
    "card": {
      "default": {
        "bg": "#ffffff",
        "border": "1px solid rgba(161, 228, 219, 0.4)",
        "borderRadius": "20px", "padding": "28px",
        "boxShadow": "0 2px 16px rgba(10, 61, 58, 0.06)"
      },
      "teal": {
        "bg": "#e8f4f1",
        "border": "1px solid #A1E4DB",
        "borderRadius": "20px", "padding": "28px"
      },
      "dark": {
        "bg": "linear-gradient(135deg, #1a4d47 0%, #0a3d3a 100%)",
        "text": "#faf7f5",
        "borderRadius": "20px", "padding": "32px"
      },
      "glass": {
        "bg": "rgba(255, 255, 255, 0.65)",
        "backdropFilter": "blur(12px)",
        "border": "1px solid rgba(255, 255, 255, 0.9)",
        "borderRadius": "20px", "padding": "28px",
        "boxShadow": "0 4px 24px rgba(10, 61, 58, 0.08)"
      }
    },
    "nav": {
      "bg": "rgba(250, 247, 245, 0.85)",
      "border": "1px solid rgba(161, 228, 219, 0.35)",
      "backdropFilter": "blur(20px)",
      "pill": true,
      "pillStyle": "max-width: 1100px; margin: 16px auto; border-radius: 16px"
    },
    "hero": {
      "bg": "radial-gradient(ellipse 100% 80% at 50% -20%, rgba(37,164,151,0.15) 0%, transparent 60%), #faf7f5",
      "gridLines": "rgba(161, 228, 219, 0.12)",
      "eyebrowColor": "#25A497",
      "headlineColor": "#0a3d3a",
      "bodyColor": "#1C5753",
      "layout": "centered, with bento grid cards below fold"
    },
    "badge": {
      "default": { "bg": "rgba(37,164,151,0.1)", "text": "#1E6E66", "border": "1px solid rgba(37,164,151,0.3)", "borderRadius": "8px" },
      "accent": { "bg": "rgba(255,107,71,0.1)", "text": "#e55a38", "border": "1px solid rgba(255,107,71,0.3)", "borderRadius": "8px" },
      "new": { "bg": "#25A497", "text": "#ffffff", "borderRadius": "8px" }
    },
    "input": {
      "bg": "#ffffff", "border": "1.5px solid rgba(161, 228, 219, 0.5)",
      "borderFocus": "1.5px solid #25A497",
      "borderRadius": "12px", "padding": "14px 16px",
      "font": "Inter", "fontSize": "15px", "color": "#0a3d3a",
      "boxShadow": "0 0 0 4px transparent",
      "boxShadowFocus": "0 0 0 4px rgba(37, 164, 151, 0.12)"
    }
  },
  "landingPageSections": {
    "hero": { "bg": "#faf7f5", "accent": "radial-gradient teal", "variant": "light-with-bento" },
    "features": { "bg": "#ffffff", "layout": "bento-grid", "variant": "white-bento" },
    "social-proof": { "bg": "#e8f4f1", "variant": "pearl-testimonials" },
    "metrics": { "bg": "linear-gradient(135deg, #0a3d3a 0%, #1a4d47 100%)", "text": "#faf7f5", "variant": "dark-metrics" },
    "pricing": { "bg": "#faf7f5", "variant": "cream-pricing" },
    "cta": { "bg": "linear-gradient(135deg, #1E6E66 0%, #0a3d3a 100%)", "accent": "#25A497", "text": "#faf7f5", "variant": "teal-gradient" },
    "footer": { "bg": "#0F3836", "text": "#e8f4f1", "variant": "dark-forest" }
  },
  "spacing": {
    "unit": 8,
    "sectionPadding": "108px 0",
    "cardPadding": "28px",
    "cardGap": "16px",
    "containerMaxWidth": "1280px",
    "contentMaxWidth": "720px",
    "borderRadius": { "sm": "10px", "md": "16px", "lg": "20px", "xl": "28px", "full": "9999px" }
  }
}
