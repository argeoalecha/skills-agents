{
  "name": "Hayah Classic",
  "id": "hayah-classic",
  "version": "2.0",
  "description": "Refined foundation theme. Elegant serif display headers meet a clean humanist sans-serif body. Cream and pearl backgrounds with deep teal navigation and coral CTAs. Best for SaaS landing pages, professional services, and product marketing sites.",
  "mood": "Sophisticated, trustworthy, premium",
  "inspiration": "Editorial SaaS — think Linear, Notion, Vercel landing pages",
  "colors": {
    "brand": {
      "primary": "#0a3d3a",
      "primaryLight": "#1C5753",
      "primaryDark": "#0F3836",
      "accent": "#ff6b47",
      "accentLight": "#ff8f73",
      "accentSubtle": "#ffb5a0"
    },
    "interactive": {
      "link": "#1E6E66",
      "linkHover": "#25A497",
      "focus": "#25A497",
      "secondary": "#25A497",
      "secondaryHover": "#A1E4DB",
      "muted": "#7a9b96"
    },
    "surface": {
      "page": "#faf7f5",
      "card": "#e8f4f1",
      "cardHover": "#d8ece8",
      "panel": "#F3FFF9",
      "overlay": "rgba(10, 61, 58, 0.06)"
    },
    "text": {
      "primary": "#0a3d3a",
      "secondary": "#1C5753",
      "muted": "#7a9b96",
      "onDark": "#faf7f5",
      "onAccent": "#ffffff"
    },
    "border": {
      "default": "#A1E4DB",
      "subtle": "#e8f4f1",
      "strong": "#1C5753"
    }
  },
  "typography": {
    "fonts": {
      "display": "DM Serif Display",
      "heading": "DM Serif Display",
      "body": "Plus Jakarta Sans",
      "mono": "JetBrains Mono"
    },
    "googleFontsUrl": "https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap",
    "scale": {
      "hero": { "size": "72px", "lineHeight": "1.1", "weight": 400, "letterSpacing": "-0.03em", "font": "DM Serif Display" },
      "display": { "size": "56px", "lineHeight": "1.15", "weight": 400, "letterSpacing": "-0.025em", "font": "DM Serif Display" },
      "h1": { "size": "40px", "lineHeight": "1.2", "weight": 400, "letterSpacing": "-0.02em", "font": "DM Serif Display" },
      "h2": { "size": "28px", "lineHeight": "1.3", "weight": 400, "letterSpacing": "-0.015em", "font": "DM Serif Display" },
      "h3": { "size": "20px", "lineHeight": "1.4", "weight": 600, "letterSpacing": "-0.01em", "font": "Plus Jakarta Sans" },
      "h4": { "size": "16px", "lineHeight": "1.5", "weight": 600, "letterSpacing": "0em", "font": "Plus Jakarta Sans" },
      "bodyLg": { "size": "18px", "lineHeight": "1.7", "weight": 400, "font": "Plus Jakarta Sans" },
      "body": { "size": "16px", "lineHeight": "1.7", "weight": 400, "font": "Plus Jakarta Sans" },
      "bodySm": { "size": "14px", "lineHeight": "1.6", "weight": 400, "font": "Plus Jakarta Sans" },
      "caption": { "size": "12px", "lineHeight": "1.5", "weight": 500, "letterSpacing": "0.02em", "font": "Plus Jakarta Sans" },
      "label": { "size": "13px", "lineHeight": "1.4", "weight": 600, "letterSpacing": "0.06em", "font": "Plus Jakarta Sans", "textTransform": "uppercase" },
      "code": { "size": "14px", "lineHeight": "1.5", "weight": 400, "font": "JetBrains Mono" }
    }
  },
  "components": {
    "button": {
      "primary": {
        "bg": "#ff6b47", "text": "#ffffff", "hover": "#e55a38",
        "padding": "14px 28px", "borderRadius": "10px",
        "font": "Plus Jakarta Sans", "fontSize": "15px", "fontWeight": 600,
        "boxShadow": "0 4px 14px rgba(255, 107, 71, 0.35)"
      },
      "secondary": {
        "bg": "transparent", "text": "#0a3d3a", "border": "2px solid #0a3d3a",
        "hover": "#0a3d3a", "hoverText": "#faf7f5",
        "padding": "12px 26px", "borderRadius": "10px",
        "font": "Plus Jakarta Sans", "fontSize": "15px", "fontWeight": 600
      },
      "ghost": {
        "bg": "transparent", "text": "#1E6E66",
        "hover": "#e8f4f1",
        "padding": "12px 20px", "borderRadius": "10px",
        "font": "Plus Jakarta Sans", "fontSize": "15px", "fontWeight": 500
      }
    },
    "card": {
      "default": {
        "bg": "#e8f4f1", "borderRadius": "16px", "padding": "32px",
        "border": "1px solid rgba(161, 228, 219, 0.5)",
        "boxShadow": "0 2px 16px rgba(10, 61, 58, 0.06)"
      },
      "elevated": {
        "bg": "#ffffff", "borderRadius": "16px", "padding": "32px",
        "boxShadow": "0 8px 32px rgba(10, 61, 58, 0.10), 0 2px 8px rgba(10, 61, 58, 0.06)"
      },
      "feature": {
        "bg": "#0a3d3a", "text": "#faf7f5", "borderRadius": "20px", "padding": "40px",
        "accentBorder": "1px solid rgba(37, 164, 151, 0.3)"
      }
    },
    "nav": {
      "bg": "#ffffff",
      "border": "1px solid rgba(161, 228, 219, 0.4)",
      "backdropFilter": "blur(12px)",
      "scrolledBg": "rgba(255, 255, 255, 0.95)"
    },
    "hero": {
      "bg": "#faf7f5",
      "accentBg": "linear-gradient(135deg, #F3FFF9 0%, #e8f4f1 100%)",
      "eyebrowColor": "#1E6E66",
      "headlineColor": "#0a3d3a",
      "bodyColor": "#1C5753"
    },
    "badge": {
      "default": { "bg": "#e8f4f1", "text": "#0a3d3a", "border": "1px solid #A1E4DB" },
      "accent": { "bg": "#ffb5a0", "text": "#7d2d15" },
      "success": { "bg": "#d4f4f1", "text": "#0a3d3a" }
    },
    "input": {
      "bg": "#ffffff", "border": "1.5px solid #A1E4DB", "borderFocus": "1.5px solid #25A497",
      "borderRadius": "10px", "padding": "14px 16px",
      "font": "Plus Jakarta Sans", "fontSize": "15px", "color": "#0a3d3a"
    }
  },
  "landingPageSections": {
    "hero": { "bg": "#faf7f5", "variant": "light-cream" },
    "features": { "bg": "#F3FFF9", "variant": "light-mint" },
    "social-proof": { "bg": "#ffffff", "variant": "pure-white" },
    "pricing": { "bg": "#e8f4f1", "variant": "pearl" },
    "cta": { "bg": "#0a3d3a", "text": "#faf7f5", "variant": "dark-teal" },
    "footer": { "bg": "#0F3836", "text": "#e8f4f1", "variant": "dark-forest" }
  },
  "spacing": {
    "unit": 8,
    "sectionPadding": "96px 0",
    "cardPadding": "32px",
    "cardGap": "24px",
    "containerMaxWidth": "1200px",
    "contentMaxWidth": "720px",
    "borderRadius": { "sm": "8px", "md": "12px", "lg": "16px", "xl": "24px", "full": "9999px" }
  }
}
